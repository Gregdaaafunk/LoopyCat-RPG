require "shellwords"
require "securerandom"
require "tmpdir"
require "time"
require "base64"
require "fileutils"
require "spaceship"
require "fastlane_core/provisioning_profile"

def verify_info_plist_orientations(plist_path, label)
  expected = {
    "UISupportedInterfaceOrientations" => [
      "UIInterfaceOrientationPortrait",
      "UIInterfaceOrientationLandscapeLeft",
      "UIInterfaceOrientationLandscapeRight"
    ],
    "UISupportedInterfaceOrientations~ipad" => [
      "UIInterfaceOrientationPortrait",
      "UIInterfaceOrientationPortraitUpsideDown",
      "UIInterfaceOrientationLandscapeLeft",
      "UIInterfaceOrientationLandscapeRight"
    ]
  }

  expected.each do |key, values|
    actual = values.each_index.map do |index|
      sh("/usr/libexec/PlistBuddy -c #{Shellwords.escape("Print :#{key}:#{index}")} #{Shellwords.escape(plist_path)}", log: false).strip
    rescue
      nil
    end

    UI.user_error!("#{label} is missing #{key}: expected #{values.join(", ")}") unless actual == values
  end

  UI.message("Verified required orientations in #{label}.")
end

def verify_info_plist_launch_screen(plist_path, label)
  launch_storyboard = sh("/usr/libexec/PlistBuddy -c #{Shellwords.escape("Print :UILaunchStoryboardName")} #{Shellwords.escape(plist_path)}", log: false).strip
  UI.user_error!("#{label} must include UILaunchStoryboardName=LaunchScreen for App Store upload.") unless launch_storyboard == "LaunchScreen"

  UI.message("Verified launch storyboard in #{label}.")
end

def verify_ipa_info_plist_orientations(ipa_path)
  Dir.mktmpdir("loopycat-ipa") do |tmpdir|
    sh("unzip -q #{Shellwords.escape(ipa_path)} -d #{Shellwords.escape(tmpdir)}")
    app_info_plists = Dir[File.join(tmpdir, "Payload", "*.app", "Info.plist")]
    UI.user_error!("Could not find packaged app Info.plist in #{ipa_path}") if app_info_plists.empty?

    verify_info_plist_orientations(app_info_plists.first, "packaged app Info.plist")
    verify_info_plist_launch_screen(app_info_plists.first, "packaged app Info.plist")
  end
end

def create_distribution_certificate(api_key, team_id, keychain_path, keychain_password, signing_directory)
  get_certificates(
    api_key: api_key,
    team_id: team_id,
    development: false,
    generate_apple_certs: true,
    force: false,
    output_path: signing_directory,
    keychain_path: keychain_path,
    keychain_password: keychain_password
  )
rescue => error
  raise unless error.message.include?("maximum number of available Distribution certificates")

  revoke_newest_distribution_certificate

  get_certificates(
    api_key: api_key,
    team_id: team_id,
    development: false,
    generate_apple_certs: true,
    force: false,
    output_path: signing_directory,
    keychain_path: keychain_path,
    keychain_password: keychain_password
  )
end

def revoke_newest_distribution_certificate
  distribution_types = [
    "DISTRIBUTION",
    "IOS_DISTRIBUTION",
    "APPLE_DISTRIBUTION"
  ]
  certificates = Spaceship::ConnectAPI::Certificate.all.select do |certificate|
    distribution_types.include?(certificate.certificate_type) && certificate.valid?
  end
  UI.user_error!("Apple blocked certificate creation and no revokable Distribution certificate was found.") if certificates.empty?

  certificate = certificates.max_by do |candidate|
    [
      Time.parse(candidate.expiration_date),
      candidate.id
    ]
  end
  UI.important("Revoking Distribution certificate #{certificate.id} (#{certificate.name || certificate.display_name}) to free a signing slot.")
  certificate.delete!
  sleep(5)
end

default_platform(:ios)

platform :ios do
  desc "Build and upload the Swift runtime prototype to TestFlight"
  lane :beta do
    ensure_required_environment

    app_identifier = ENV.fetch("APP_IDENTIFIER")
    team_id = ENV.fetch("APPLE_TEAM_ID")
    project_path = "LoopyCatRuntimePrototype.xcodeproj"
    scheme = "LoopyCatRuntimePrototype"
    output_directory = "build"
    output_name = "LoopyCatRuntimePrototype.ipa"
    source_info_plist = "LoopyCatRuntimePrototype/Info.plist"
    profile_directory = File.join(output_directory, "profiles")
    profile_name = ENV.fetch("PROVISIONING_PROFILE_NAME", "#{scheme} App Store")
    keychain_name = "loopycat-ci-#{SecureRandom.hex(8)}"
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    keychain_password = SecureRandom.hex(32)
    project_root = File.expand_path("..", __dir__)
    project_path_absolute = File.join(project_root, project_path)
    output_directory_absolute = File.join(project_root, output_directory)
    profile_directory_absolute = File.join(project_root, profile_directory)
    source_info_plist_absolute = File.join(project_root, source_info_plist)
    signing_directory = File.join(output_directory_absolute, "signing")
    certificate_path = File.join(signing_directory, "distribution_certificate.p12")

    Dir.chdir(project_root) do
      sh("xcodegen generate")
      verify_info_plist_orientations(source_info_plist_absolute, "source Info.plist after xcodegen generate")
      verify_info_plist_launch_screen(source_info_plist_absolute, "source Info.plist after xcodegen generate")

      api_key = app_store_connect_api_key(asc_api_key_options)

      begin
        create_keychain(
          name: keychain_name,
          password: keychain_password,
          default_keychain: true,
          unlock: true,
          timeout: 3600,
          lock_when_sleeps: false
        )

        certificate_base64 = ENV["IOS_DISTRIBUTION_CERTIFICATE_BASE64"].to_s.strip
        certificate_password = ENV["IOS_DISTRIBUTION_CERTIFICATE_PASSWORD"].to_s
        if certificate_base64.empty?
          create_distribution_certificate(api_key, team_id, keychain_path, keychain_password, signing_directory)
        else
          UI.user_error!("Missing required GitHub secret: IOS_DISTRIBUTION_CERTIFICATE_PASSWORD") if certificate_password.empty?

          FileUtils.mkdir_p(signing_directory)
          File.binwrite(certificate_path, Base64.decode64(certificate_base64))

          import_certificate(
            certificate_path: certificate_path,
            certificate_password: certificate_password,
            keychain_name: keychain_name,
            keychain_password: keychain_password
          )
        end

        get_provisioning_profile(
          api_key: api_key,
          team_id: team_id,
          app_identifier: app_identifier,
          provisioning_name: profile_name,
          output_path: profile_directory_absolute,
          filename: "#{app_identifier}.appstore.mobileprovision",
          skip_install: false,
          force: true
        )

        profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]
        UI.user_error!("Could not resolve generated provisioning profile path.") if profile_path.to_s.empty?

        profile = FastlaneCore::ProvisioningProfile.parse(profile_path)
        resolved_profile_name = profile["Name"] || profile_name

        update_code_signing_settings(
          use_automatic_signing: false,
          path: project_path_absolute,
          team_id: team_id,
          targets: [scheme],
          bundle_identifier: app_identifier,
          profile_name: resolved_profile_name,
          code_sign_identity: "Apple Distribution"
        )

        latest_build = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: app_identifier,
          initial_build_number: 0
        )
        next_build = latest_build + 1

        increment_build_number(
          build_number: next_build.to_s,
          xcodeproj: project_path_absolute
        )

        xcargs = [
          "PRODUCT_BUNDLE_IDENTIFIER=#{app_identifier.shellescape}",
          "DEVELOPMENT_TEAM=#{team_id.shellescape}",
          "CODE_SIGN_STYLE=Manual",
          "CODE_SIGN_IDENTITY=#{'Apple Distribution'.shellescape}",
          "PROVISIONING_PROFILE_SPECIFIER=#{resolved_profile_name.shellescape}"
        ]

        build_app(
          project: project_path_absolute,
          scheme: scheme,
          clean: true,
          destination: "generic/platform=iOS",
          export_method: "app-store",
          export_options: {
            method: "app-store",
            signingStyle: "manual",
            teamID: team_id,
            provisioningProfiles: {
              app_identifier => resolved_profile_name
            }
          },
          xcargs: xcargs.join(" "),
          output_directory: output_directory_absolute,
          output_name: output_name
        )
        verify_ipa_info_plist_orientations(File.join(output_directory_absolute, output_name))

        groups = ENV["TESTFLIGHT_GROUPS"].to_s.split(",").map(&:strip).reject(&:empty?)

        upload_options = {
          api_key: api_key,
          app_identifier: app_identifier,
          ipa: File.join(output_directory_absolute, output_name),
          skip_waiting_for_build_processing: groups.empty?,
          changelog: ENV.fetch("TESTFLIGHT_CHANGELOG", "PHOTO composition prototype build")
        }
        upload_options[:groups] = groups unless groups.empty?

        upload_to_testflight(upload_options)
      ensure
        delete_keychain(name: keychain_name) if keychain_name
      end
    end
  end

  private_lane :ensure_required_environment do
    required = [
      "APPLE_TEAM_ID",
      "APP_IDENTIFIER",
      "ASC_KEY_ID",
      "ASC_ISSUER_ID"
    ]

    missing = required.select { |key| ENV[key].to_s.strip.empty? }
    UI.user_error!("Missing required environment variables: #{missing.join(", ")}") unless missing.empty?

    if ENV["ASC_PRIVATE_KEY"].to_s.strip.empty?
      UI.user_error!("Missing required environment variable: ASC_PRIVATE_KEY or ASC_KEY_PATH") if ENV["ASC_KEY_PATH"].to_s.strip.empty?

      key_path = ENV.fetch("ASC_KEY_PATH")
      UI.user_error!("ASC_KEY_PATH does not exist: #{key_path}") unless File.exist?(key_path)
    end
  end

  private_lane :asc_api_key_options do
    options = {
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      duration: 1200,
      in_house: false
    }

    private_key = ENV["ASC_PRIVATE_KEY"].to_s.strip
    if private_key.empty?
      options[:key_filepath] = ENV.fetch("ASC_KEY_PATH")
    else
      options[:key_content] = private_key.gsub("\\n", "\n")
    end

    options
  end
end
